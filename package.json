{
  "name": "scout-extension",
  "version": "0.11.0",
  "private": true,
  "description": "Private, review-first job application CRM and autofill assistant.",
  "scripts": {
    "lint": "node scripts/check.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "test": "node --test tests/*.test.mjs",
    "test:browser": "node scripts/browser-test.mjs",
    "test:browser:dist": "node scripts/browser-test.mjs --extension-dir=dist",
    "test:production-build": "node scripts/check-production-build.mjs",
    "db:start": "npx supabase@2.109.1 start",
    "db:reset": "npx supabase@2.109.1 db reset",
    "db:test": "npx supabase@2.109.1 test db",
    "db:lint": "npx supabase@2.109.1 db lint --schema public --level warning --fail-on warning",
    "build": "node scripts/build.mjs",
    "build:production": "SCOUT_BUILD_MODE=production node scripts/build.mjs",
    "verify": "npm run lint && npm run typecheck && npm test && npm run build && npm run test:browser:dist"
  },
  "devDependencies": {
    "pdfjs-dist": "^5.4.624",
    "playwright": "^1.61.1",
    "typescript": "^5.8.3"
  }
}
