{
  "manifest_version": 3,
  "name": "Scout",
  "version": "0.11.0",
  "description": "A private, review-first job application CRM and autofill assistant.",
  "permissions": ["storage", "unlimitedStorage", "alarms", "webNavigation", "identity"],
  "host_permissions": ["https://hkmrpkxiaadhlwpieyve.supabase.co/*"],
  "optional_host_permissions": ["http://localhost:11434/*", "http://127.0.0.1:11434/*", "http://localhost:54321/*", "http://127.0.0.1:54321/*"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/icons/scout-16.png",
    "32": "assets/icons/scout-32.png",
    "48": "assets/icons/scout-48.png",
    "128": "assets/icons/scout-128.png"
  },
  "action": {
    "default_title": "Scout",
    "default_icon": {
      "16": "assets/icons/scout-16.png",
      "32": "assets/icons/scout-32.png"
    },
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["shared/constants.js", "shared/matching.js", "shared/offlyn-core.js", "shared/profiles.js", "shared/ai.js", "shared/graph.js", "shared/agent.js", "shared/ats-compat.js", "shared/workday.js", "shared/diagnostics.js", "shared/submission.js", "capture.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ]
}
